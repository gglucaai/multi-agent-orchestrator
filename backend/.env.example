# =====================================================
# AI AGENTS ORCHESTRATOR - Configuration
# =====================================================

# Hugging Face API Token (FREE)
# Get one at: https://huggingface.co/settings/tokens
# Required permissions: "Make calls to Inference Providers"
HF_API_TOKEN=hf_your_token_here

# Optional: Override default model
# RECOMMENDED MODELS (no gated access needed):
#   Qwen/Qwen2.5-72B-Instruct           - Top performer, recommended default
#   deepseek-ai/DeepSeek-V3              - Excellent reasoning
#   mistralai/Mixtral-8x7B-Instruct-v0.1 - Fast and reliable
#
# HF_MODEL=Qwen/Qwen2.5-72B-Instruct

# =====================================================
# Optional: Anthropic Claude API (if using main.py)
# =====================================================
# ANTHROPIC_API_KEY=sk-ant-...
